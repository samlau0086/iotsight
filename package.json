{
  "name": "iotedges-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node scripts/prerender.mjs && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc",
    "verify:cms": "node scripts/verify-cms-rollout.mjs",
    "verify:cms-runtime": "tsx scripts/smoke-decap-auth-worker.ts",
    "verify:cms-build": "node scripts/verify-cms-build-output.mjs",
    "verify:draft-visibility": "node scripts/verify-draft-visibility.mjs",
    "verify:server-surface": "node scripts/verify-built-server-surface.mjs",
    "verify:cms-external-config": "node scripts/verify-cms-external-config.mjs",
    "verify:auth-worker-surface": "node scripts/verify-auth-worker-surface.mjs",
    "verify:production-surface": "node scripts/verify-production-surface.mjs",
    "verify:live-route-samples": "node scripts/verify-live-route-samples.mjs",
    "verify:cms-live-surface": "node scripts/verify-cms-live-surface.mjs",
    "verify:cms-go-live": "node scripts/verify-cms-go-live.mjs",
    "verify:cms-auth-preflight": "npm run verify:cms && npm run verify:cms-runtime",
    "verify:cms-preflight": "npm run lint && npm run verify:cms && npm run verify:cms-runtime && npm run build && npm run verify:cms-build && npm run verify:draft-visibility && npm run verify:server-surface",
    "create:cms-dry-run-report": "node scripts/create-cms-dry-run-report.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
