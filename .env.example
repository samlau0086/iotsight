# GEMINI_API_KEY: Optional key for server-side Gemini API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://iotedges.com"

# Optional public Google Analytics 4 measurement ID.
# This is injected into prerendered HTML during build.
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Optional public Google Tag Manager container ID.
# This is injected into prerendered HTML during build.
VITE_GTM_ID="GTM-XXXXXXX"

# PORT: Optional production HTTP port. Defaults to 3005.
PORT=3005

# LIVE_CHAT_API_TOKEN: Private live chat provider token.
# Keep this server-side only. Do not expose it with a VITE_ prefix.
LIVE_CHAT_API_TOKEN="MY_LIVE_CHAT_API_TOKEN"

# LIVE_CHAT_API_BASE_URL: TradeQuest CRM origin that hosts the live chat API.
# Example: https://crm.example.com
LIVE_CHAT_API_BASE_URL="https://crm.example.com"
