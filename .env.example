# GEMINI_API_KEY: Optional key for server-side Gemini API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public site URL.
# Used for self-referential links, sitemap generation, and CMS URL consistency checks.
APP_URL="https://iotedges.com"

# Optional public Google Analytics 4 measurement ID.
# This is injected into prerendered HTML during build.
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Optional public Google Tag Manager container ID.
# This is injected into prerendered HTML during build.
VITE_GTM_ID="GTM-XXXXXXX"

# PORT: Optional production HTTP port. Defaults to 3005.
PORT=3005

# LIVE_CHAT_API_BASE_URL: ai-agent-live-chat deployment origin.
# Defaults to https://chat.iotedges.com when omitted.
LIVE_CHAT_API_BASE_URL="https://chat.iotedges.com"
