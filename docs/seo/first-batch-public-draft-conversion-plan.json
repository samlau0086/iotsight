    "database": "first-batch-public-draft-conversion-plan",
    "version": "0.1.0",
    "last_updated": "2026-06-09",
    "status": "draft_conversion_plan",
    "purpose": "Decide which first-batch model-specific safe-scope briefs can be converted into public website draft pages using only safe or conditional wording, and which pages should remain internal until prototype validation.",
    "important_note": "This plan allows early SEO draft pages only when exact specifications are withheld. It does not approve final datasheet-style pages."
  },
  "conversion_status_values": {
    "public_safe_draft_candidate": "Can become a public draft page if all blocked and forbidden claims are removed and wording stays conditional.",
    "internal_only_until_validation": "Should remain internal because the page depends too heavily on unvalidated hardware, RF, cellular or electrical claims.",
    "wait_for_prototype": "Should wait for prototype or module validation before public drafting.",
    "not_ready": "Insufficient structure or claim control."
  },
  "public_draft_rules": [
    "Use planned, designed for, target, intended for and under validation wording.",
    "Do not show exact relay rating, analog accuracy, operating temperature, IP rating, isolation voltage, LTE bands, WiFi range, LoRa range or certifications.",
    "Do not publish full register maps or payload schemas as final API specifications until firmware is validated.",
    "Do not add comparison tables that imply unavailable features are supported.",
    "Do not add datasheet-style spec tables unless every value is marked planned or validation-gated.",
    "Every public draft must include a short validation-status note.",
    "Every public draft must link to relevant product, solution and knowledge pages."
  ],
  "recommended_public_draft_batch": [
