{
  "meta": {
    "project": "IoTEdges",
    "database": "first-batch-product-page-capability-review-matrix",
    "version": "0.1.0",
    "last_updated": "2026-06-09",
    "status": "draft_review_matrix",
    "purpose": "Capability and claim review matrix for the first-batch model-specific safe-scope Markdown briefs before they are converted into public website product pages.",
    "important_note": "This matrix reviews page claims, not hardware test results. A public page can only use exact specifications after the related claim is validated through engineering evidence, prototype test reports and product approval."
  },
  "review_status_values": {
    "safe": "Claim can be used with planning or category-level wording.",
    "conditional": "Claim can be used only with validation wording such as planned, target, designed for, or under validation.",
    "blocked": "Claim should not appear until engineering evidence exists.",
    "forbidden": "Claim must not appear for this model."
  },
  "global_rules": [
    {
      "rule_id": "no-5g",
      "status": "forbidden",
      "rule": "Do not claim 5G support on any first-generation product page."
    },
    {
      "rule_id": "separate-wireless-uplink",
      "status": "forbidden",
      "rule": "Do not combine 4G, WiFi and LoRa/LoRaWAN in one model. Each wireless uplink must remain a separate SKU or product family."
    },
    {
      "rule_id": "baseline-gateway-protocol-boundary",
      "status": "forbidden",
      "rule": "Do not claim OPC UA, BACnet or CAN on baseline IEG-100, IEG-120 or IEG-140 gateway pages."
    },
    {
      "rule_id": "no-unvalidated-electrical-specs",
      "status": "blocked",
      "rule": "Do not publish exact relay rating, analog accuracy, isolation voltage, ESD/surge level, temperature range, IP rating or certifications until validated."
    },
    {
      "rule_id": "safe-public-language",
      "status": "safe",
      "rule": "Use planning-safe language such as planned, designed for, target, intended for and under validation until evidence exists."
    }
  ],
