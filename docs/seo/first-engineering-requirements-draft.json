  "shared_engineering_assumptions": {
    "power": {
      "target_input": "9-36VDC preferred; 12-24VDC acceptable if BOM/cost requires it",
      "protection_targets": ["reverse polarity protection", "surge/ESD protection", "watchdog recovery"]
    },
    "mounting_and_enclosure": {
      "mounting": "DIN rail baseline",
      "enclosure": "industrial cabinet enclosure; outdoor/IP-rated enclosure only for selected variants",
      "temperature_target": "-20C to +70C planning target"
    },
    "configuration": {
      "baseline": ["local web UI where Ethernet exists", "device status page", "configuration export/import"],
      "rtu_required_pages": ["network settings", "Modbus settings", "IO status", "alarm rules", "MQTT settings if supported"],
      "remote_io_required_settings": ["Modbus address", "baud rate", "parity", "IO mode", "failsafe behavior"]
    },
    "claim_policy": [
      "RTU baseline IO planning decision is 4DI + 2DO/relay + 2AI.",
      "IEIO-100 Remote IO planning decision is to start with separate IO-type variants instead of one overloaded mixed IO module.",
      "Do not publish exact electrical ratings until hardware is locked.",
      "Do not publish relay ratings, analog accuracy, isolation voltage or surge ratings until tested.",
      "Do not claim certifications such as CE/FCC/UL/ATEX/IECEx until certificates exist."
    ]
  },
